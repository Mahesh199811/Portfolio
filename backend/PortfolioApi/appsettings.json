{
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DB_HOST};Port=5432;Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}"
  },
  "AWS": {
    "Region": "ap-south-1",
    "SES": {
      "FromEmail": "${SES_FROM_EMAIL}",
      "ToEmail": "${SES_TO_EMAIL}"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
